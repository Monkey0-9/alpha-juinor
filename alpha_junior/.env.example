# Alpha Junior - Environment Configuration
# Copy this file to .env and fill in your values

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
POSTGRES_SERVER=postgres
POSTGRES_USER=alpha_junior
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=alpha_junior
DATABASE_URL=postgresql+asyncpg://alpha_junior:your_secure_password_here@postgres:5432/alpha_junior

# ==========================================
# REDIS CONFIGURATION
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==========================================
# SECURITY CONFIGURATION
# ==========================================
# Generate RSA keys: openssl genrsa -out private.pem 2048
# Extract public key: openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
YOUR_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
YOUR_PUBLIC_KEY_HERE
-----END PUBLIC KEY-----"

# Generate with: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here

# ==========================================
# 2FA CONFIGURATION
# ==========================================
TOTP_ISSUER_NAME=Alpha Junior

# ==========================================
# S3 / FILE STORAGE CONFIGURATION
# ==========================================
# For AWS S3
S3_ENDPOINT_URL=
S3_BUCKET_NAME=alpha-junior-documents
S3_ACCESS_KEY=your_aws_access_key
S3_SECRET_KEY=your_aws_secret_key
S3_REGION=us-east-1

# For Cloudflare R2 (alternative)
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# S3_BUCKET_NAME=alpha-junior
# S3_ACCESS_KEY=your_r2_access_key
# S3_SECRET_KEY=your_r2_secret_key

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@alphajunior.com
SMTP_FROM_NAME=Alpha Junior

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ==========================================
# EXTERNAL APIs (Get free keys at listed URLs)
# ==========================================
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=demo

# NewsAPI: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key

# FRED: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# ==========================================
# MONITORING & LOGGING
# ==========================================
LOG_LEVEL=INFO
GRAFANA_PASSWORD=admin
SENTRY_DSN=  # Optional: https://sentry.io

# ==========================================
# KYC PROVIDER (Optional)
# ==========================================
# Sumsub: https://sumsub.com
# Onfido: https://onfido.com
# Jumio: https://jumio.com
KYC_VERIFICATION_PROVIDER=
KYC_API_KEY=
KYC_API_SECRET=

# ==========================================
# PAYMENT PROCESSING (Optional)
# ==========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ==========================================
# DOCKER / DEPLOYMENT
# ==========================================
COMPOSE_PROJECT_NAME=alpha_junior
DOCKER_BUILDKIT=1
