{
  "market_data": {
    "feeds": [
      {
        "source": "alpaca",
        "enabled": true,
        "priority": 1,
        "api_key": "${ALPACA_API_KEY}",
        "secret_key": "${ALPACA_SECRET_KEY}",
        "base_url": "https://data.alpaca.markets"
      },
      {
        "source": "polygon",
        "enabled": true,
        "priority": 2,
        "api_key": "${POLYGON_API_KEY}",
        "host": "api.polygon.io",
        "port": 443
      },
      {
        "source": "yahoo",
        "enabled": true,
        "priority": 3,
        "host": "query1.finance.yahoo.com",
        "port": 443
      }
    ],
    "verify_data": true,
    "quality_threshold": 0.80
  },
  "brokers": [
    {
      "type": "alpaca",
      "enabled": true,
      "priority": 1,
      "api_key": "${ALPACA_API_KEY}",
      "secret_key": "${ALPACA_SECRET_KEY}",
      "base_url": "https://paper-api.alpaca.markets",
      "paper": true
    }
  ],
  "risk_management": {
    "position_limits": [
      {
        "symbol": "AAPL",
        "asset_class": "equity",
        "max_position": 1000,
        "max_notional": 150000,
        "max_percentage": 0.15
      },
      {
        "symbol": "GOOGL",
        "asset_class": "equity",
        "max_position": 500,
        "max_notional": 100000,
        "max_percentage": 0.10
      },
      {
        "symbol": "MSFT",
        "asset_class": "equity",
        "max_position": 800,
        "max_notional": 250000,
        "max_percentage": 0.12
      },
      {
        "symbol": "TSLA",
        "asset_class": "equity",
        "max_position": 300,
        "max_notional": 60000,
        "max_percentage": 0.05
      }
    ],
    "circuit_breakers": [
      {
        "name": "portfolio_drawdown",
        "type": "drawdown_limit",
        "threshold": 10000,
        "action": "stop_trading",
        "auto_reset": true,
        "reset_minutes": 30
      },
      {
        "name": "daily_loss_limit",
        "type": "loss_limit",
        "threshold": 5000,
        "action": "stop_trading",
        "auto_reset": true,
        "reset_minutes": 60
      },
      {
        "name": "price_movement",
        "type": "price_movement",
        "symbol": "SPY",
        "threshold": 0.05,
        "action": "reduce_positions",
        "auto_reset": true,
        "reset_minutes": 15
      }
    ],
    "max_portfolio_var": 10000,
    "max_leverage": 2.0
  },
  "compliance": {
    "regulations": ["FINRA", "SEC"],
    "reporting_schedule": {
      "trade_reports": "daily",
      "position_reports": "daily",
      "compliance_reports": "weekly"
    },
    "encryption_password": "${COMPLIANCE_ENCRYPTION_PASSWORD}",
    "paper_trading_mode": true
  },
  "security": {
    "master_password": "${SECURITY_MASTER_PASSWORD}",
    "session_timeout_hours": 24,
    "max_failed_attempts": 10,
    "lockout_minutes": 15,
    "paper_trading_mode": true
  },
  "high_availability": {
    "consul": {
      "enabled": false
    },
    "etcd": {
      "enabled": false
    },
    "redis": {
      "enabled": true,
      "host": "localhost",
      "port": 6379,
      "db": 1
    },
    "database": {
      "enabled": true,
      "host": "localhost",
      "port": 5432,
      "database": "miniquantfund_paper",
      "user": "postgres",
      "password": "${DB_PASSWORD}",
      "sslmode": "prefer",
      "min_connections": 2,
      "max_connections": 10
    },
    "kubernetes": {
      "enabled": false
    }
  },
  "monitoring": {
    "prometheus": {
      "enabled": true,
      "port": 9091
    },
    "grafana": {
      "enabled": true,
      "host": "localhost",
      "port": 3001,
      "auth": "${GRAFANA_AUTH}"
    },
    "thresholds": [
      {
        "metric_name": "cpu_usage",
        "component": "trading_engine",
        "warning_threshold": 85,
        "critical_threshold": 95,
        "operator": ">",
        "duration_seconds": 300
      },
      {
        "metric_name": "memory_usage",
        "component": "trading_engine",
        "warning_threshold": 85,
        "critical_threshold": 95,
        "operator": ">",
        "duration_seconds": 300
      },
      {
        "metric_name": "portfolio_var_1d",
        "component": "risk_manager",
        "warning_threshold": 8000,
        "critical_threshold": 10000,
        "operator": ">",
        "duration_seconds": 60
      }
    ]
  },
  "paper_trading": {
    "initial_capital": 1000000,
    "commission_per_trade": 1.0,
    "slippage_model": "percentage",
    "slippage_rate": 0.001,
    "realistic_fills": true,
    "market_impact_model": "simple",
    "simulation_speed": "real_time",
    "data_quality_checks": true,
    "order_validation": true,
    "risk_validation": true,
    "compliance_validation": true
  },
  "logging": {
    "level": "DEBUG",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  }
}
