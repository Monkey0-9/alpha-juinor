{
  "title": "Institutional Trading Operations",
  "panels": [
    {
      "title": "Portfolio NAV",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "portfolio_nav_usd", "legendFormat": "NAV" }
      ]
    },
    {
      "title": "Execution Latency (p95)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(execution_duration_ms_bucket[5m])) by (le))" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Recent Signal Quality",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "avg(signal_confidence) by (symbol)" }
      ]
    },
    {
      "title": "Trade Execution Log",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "targets": [
        { "expr": "execution_result_info", "format": "table" }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "Symbol",
        "type": "query",
        "query": "label_values(execution_result_info, symbol)"
      }
    ]
  }
}
