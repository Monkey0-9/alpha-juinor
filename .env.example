# --- Alpaca Credentials ---
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here
ALPACA_PAPER_TRADING=true

# --- Nexus Platform Settings ---
NEXUS_API_KEY=generate_a_secure_random_key_for_internal_auth
NEXUS_API_PORT=8001
NEXUS_STREAMLIT_PORT=8501
NEXUS_BACKEND_URL=http://127.0.0.1:8001
NEXUS_ALLOW_SIMULATION_FALLBACK=false

# --- Institutional Constraints ---
NEXUS_MAX_POSITION_SIZE=0.05
NEXUS_MAX_DRAWDOWN=0.15
NEXUS_MAX_OPEN_POSITIONS=12
NEXUS_MAX_DAILY_TRADES=50
NEXUS_MIN_ORDER_USD=100

# --- Performance & Scaling ---
NEXUS_MAX_UNIVERSE_ASSETS=1000
NEXUS_CANDIDATE_POOL_SIZE=100
NEXUS_HEARTBEAT_INTERVAL=60
NEXUS_RESCAN_INTERVAL=14400

# --- Risk Parameters ---
NEXUS_TAKE_PROFIT=0.08
NEXUS_STOP_LOSS=-0.04
NEXUS_FALLBACK_EQUITY=100000.0

# --- Blacklist ---
# Comma-separated list of symbols to never trade
NEXUS_BLACKLIST=ZOMBIE,SCAM,DANGER
