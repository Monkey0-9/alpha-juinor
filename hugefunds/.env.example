# HUGEFUNDS - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/hugefunds
TIMESCALE_URL=postgresql://user:password@localhost:5432/hugefunds
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# ALPACA PAPER TRADING API
# Get from: https://alpaca.markets/
# =============================================================================
ALPACA_API_KEY=PK_YOUR_KEY_HERE
ALPACA_SECRET_KEY=YOUR_SECRET_KEY_HERE
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# =============================================================================
# ALPHA VANTAGE (Alternative Data)
# Get from: https://www.alphavantage.co/support/#api-key
# =============================================================================
ALPHA_VANTAGE_API_KEY=YOUR_AV_KEY_HERE

# =============================================================================
# SECURITY & AUTHENTICATION
# =============================================================================
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# RISK CONFIGURATION
# =============================================================================
MAX_POSITION_PCT=0.10
MAX_SECTOR_PCT=0.30
MAX_GROSS_EXPOSURE=1.50
MAX_VAR_95_PCT=0.03
MAX_DRAWDOWN_PCT=0.15
MIN_CASH_PCT=0.05
STOP_LOSS_PCT=0.08
TAKE_PROFIT_PCT=0.20

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
PAPER_TRADING=true
LIVE_TRADING=false
MAX_ORDER_SIZE=100000
DEFAULT_ORDER_TYPE=TWAP
EXECUTION_VENUE=SMART

# =============================================================================
# ML PIPELINE CONFIGURATION
# =============================================================================
MODEL_TRAINING_FREQUENCY=daily
MODEL_RETRAIN_THRESHOLD=0.05
SHADOW_MODE_DAYS=30
PAPER_MODE_DAYS=90
MIN_TRACK_RECORD_DAYS=1260

# =============================================================================
# NOTIFICATIONS
# =============================================================================
SLACK_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
ALERT_EMAIL=

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO
WORKERS=4

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_WEBSOCKET=true
ENABLE_STRESS_TESTING=true
ENABLE_ML_PREDICTIONS=true
ENABLE_GOVERNANCE_GATE=true
ENABLE_KILL_SWITCH=true
ENABLE_AUTO_TRADING=false
